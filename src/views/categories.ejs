<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    
    <% if (categories && categories.length > 0) { %>
        <ul>
            <% categories.forEach(category => { %>
                <li><%= category.name %></li>
            <% }); %>
        </ul>
    <% } else { %>
        <p>No categories available at this time.</p>
    <% } %>
</main>

<%- include('partials/footer') %>