<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <h2>Upcoming Service Projects</h2>
    
    <% if (projects && projects.length > 0) { %>
        <ul>
            <% projects.forEach(project => { %>
                <li>
                    <strong><%= new Date(project.date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></strong>: 
                    <%= project.title %> 
                    (<em><%= project.organization_name %></em>)
                </li>
            <% }); %>
        </ul>
    <% } else { %>
        <p>No service projects available at this time.</p>
    <% } %>
</main>

<%- include('partials/footer') %>